// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          Int       @id @default(autoincrement())
  name        String
  email       String    @unique
  phone       String
  password    String
  gender      String?
  role        String?
  cpf         String
  dateOfBirth DateTime
  lock        DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  address Address[]
  ratings Ratings[]

  replyRating ReplyRating[]
}

model Address {
  id           Int      @id @default(autoincrement())
  idDefault    Boolean  @default(false)
  name         String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId Int?
  user   User? @relation(fields: [userId], references: [id])
}

model Category {
  id       Int    @id @default(autoincrement())
  name     String
  fatherId Int?

  category   Category?  @relation("CategoryAutoRelation", fields: [fatherId], references: [id])
  categories Category[] @relation("CategoryAutoRelation")

  Products Products[]
}

model Brand {
  id       Int        @id @default(autoincrement())
  name     String
  Products Products[]
}

model Image {
  id        Int      @id @default(autoincrement())
  name      String
  path      String
  order     Int?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId Int?
  product   Products? @relation(fields: [productId], references: [id])
}

model UnitMeansurement {
  id        Int        @id @default(autoincrement())
  name      String
  shortName String
  Products  Products[]
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Products[]
}

model Products {
  id          Int       @id @default(autoincrement())
  name        String
  type        String
  sku         String
  externalId  String?
  barcode     String?
  shortName   String
  description String
  width       Decimal?
  height      Decimal?
  depth       Decimal?
  weight      Decimal?
  dateStart   DateTime?
  dateEnd     DateTime?
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])

  brandId Int?
  brand   Brand? @relation(fields: [brandId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images Image[]

  unitMeansurementId Int?
  unitMeansurement   UnitMeansurement? @relation(fields: [unitMeansurementId], references: [id])

  Stock Stock[]

  tags Tag[]

  ratings Ratings[]

  tablePriceProducts TablePriceProducts[]
}

model Stock {
  id        Int       @id @default(autoincrement())
  amount    Int
  costPrice Decimal?
  control   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  productId Int?
  product   Products? @relation(fields: [productId], references: [id])
}

model Ratings {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId Int
  product   Products @relation(fields: [productId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  replyRating ReplyRating[]
}

model ReplyRating {
  id        Int      @id @default(autoincrement())
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ratingId Int
  rating   Ratings @relation(fields: [ratingId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])
}

model TablePrice {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  default     Boolean   @default(false)
  promotion   Boolean   @default(false)
  value       Decimal?
  type        String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tablePriceProducts TablePriceProducts[]
}

model TablePriceProducts {
  id           Int        @id @default(autoincrement())
  tablePriceId Int
  tablePrice   TablePrice @relation(fields: [tablePriceId], references: [id])
  productId    Int
  product      Products   @relation(fields: [productId], references: [id])
  value        Decimal?
  type         String?
}
